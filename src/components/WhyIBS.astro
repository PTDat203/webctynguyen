---
import { whyIbs, ui } from '../data/site';
import Icon from './Icon.astro';
import T from './T.astro';
---
<section data-why-ibs class="why-ibs-gradient gradient-accent-top py-24 md:py-28">
  <div class="container-ibs">
    <div data-section-header class="mx-auto max-w-2xl text-center">
      <p class="section-overline overline mb-4"><T t={ui.whyIbs.overline} /></p>
      <h2 class="section-title font-display text-3xl font-bold text-white md:text-[2.4rem]">
        <T t={ui.whyIbs.title} />
      </h2>
      <span class="section-divider gold-line-metallic mx-auto mt-5 block h-px w-16 origin-center"></span>
    </div>

    <div class="mt-16 grid gap-12 sm:grid-cols-2 lg:grid-cols-4">
      {
        whyIbs.map((w) => (
          <div data-why-item class="text-center">
            <div data-why-circle class="mx-auto grid h-14 w-14 place-items-center rounded-full border border-gold/40 text-gold">
              <Icon name={w.icon} draw class="h-7 w-7" />
            </div>
            <h3 data-why-title class="mt-6 font-display text-lg font-semibold text-white"><T t={w.title} /></h3>
            <p data-why-body class="mt-2.5 text-sm font-light leading-relaxed text-white/65"><T t={w.body} /></p>
          </div>
        ))
      }
    </div>
  </div>
</section>
