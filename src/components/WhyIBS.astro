---
import { whyIbs } from '../data/site';
import Icon from './Icon.astro';
---
<section data-why-ibs class="why-ibs-gradient bg-navy py-24 md:py-28">
  <div class="container-ibs">
    <div data-section-header class="mx-auto max-w-2xl text-center">
      <p class="section-overline overline mb-4">Vì sao chọn IBS</p>
      <h2 class="section-title font-display text-3xl font-bold text-white md:text-[2.4rem]">
        Chi phí tối thiểu — Hiệu quả tối đa
      </h2>
      <span class="section-divider mx-auto mt-5 block h-px w-16 origin-center bg-gold"></span>
    </div>

    <div class="mt-16 grid gap-12 sm:grid-cols-2 lg:grid-cols-4">
      {
        whyIbs.map((w) => (
          <div data-why-item class="text-center">
            <div data-why-circle class="mx-auto grid h-14 w-14 place-items-center rounded-full border border-gold/40 text-gold">
              <Icon name={w.icon} draw class="h-7 w-7" />
            </div>
            <h3 data-why-title class="mt-6 font-display text-lg font-semibold text-white">{w.title}</h3>
            <p data-why-body class="mt-2.5 text-sm font-light leading-relaxed text-white/65">{w.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
