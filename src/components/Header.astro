---
import { Image } from 'astro:assets';
import { company, ui } from '../data/site';
import Icon from './Icon.astro';
import T from './T.astro';
import logo from '../assets/logo-ibs.png';
---
<header
  id="site-header"
  class="fixed left-0 right-0 top-0 z-50 border-b border-mist bg-white/90 backdrop-blur transition-shadow duration-300"
>
  <div data-header-inner class="container-ibs flex h-16 items-center justify-between md:h-20">
    <a
      href="#home"
      data-header-logo
      data-magnetic
      class="flex items-center origin-left"
      data-aria-label-vi={ui.cta.home.vi}
      data-aria-label-en={ui.cta.home.en}
      aria-label={ui.cta.home.vi}
    >
      <Image
        src={logo}
        alt="IBS — International Business Services"
        densities={[1, 1.5, 2]}
        quality={100}
        class="h-14 w-auto md:h-[4.5rem]"
      />
    </a>

    <nav class="hidden items-center gap-9 lg:flex" aria-label="Điều hướng chính">
      {
        ui.nav.map((item) => (
          <a
            href={item.href}
            data-nav-link
            class="nav-link relative py-2 text-[0.92rem] font-medium text-navy/75 transition-colors hover:text-navy"
          >
            <T t={item.label} />
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3 md:gap-4">
      <a
        href={company.hotlineHref}
        class="hidden items-center gap-2 text-sm font-semibold text-navy transition-colors hover:text-gold xl:inline-flex"
      >
        <Icon name="phone" class="h-4 w-4 text-gold" />
        {company.hotline}
      </a>

      <div class="lang-switch" role="group" aria-label="Language / Ngôn ngữ">
        <button type="button" data-lang-btn="vi">VN</button>
        <button type="button" data-lang-btn="en">EN</button>
      </div>

      <a href="#lien-he" data-magnetic data-ripple class="btn btn-primary hidden sm:inline-flex"><T t={ui.cta.consult} /></a>
      <button
        id="menu-toggle"
        type="button"
        class="grid h-10 w-10 place-items-center rounded text-navy lg:hidden"
        data-aria-label-vi={ui.cta.openMenu.vi}
        data-aria-label-en={ui.cta.openMenu.en}
        aria-label={ui.cta.openMenu.vi}
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Icon name="menu" class="h-6 w-6" id="menu-icon" />
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden border-t border-mist bg-white lg:hidden">
    <nav class="container-ibs flex flex-col py-3" aria-label="Điều hướng di động">
      {
        ui.nav.map((item) => (
          <a
            href={item.href}
            data-mobile-link
            class="border-b border-mist py-3 text-base font-medium text-navy/85"
          >
            <T t={item.label} />
          </a>
        ))
      }
      <a href={company.hotlineHref} data-mobile-link class="flex items-center gap-2 py-3 text-base font-semibold text-navy">
        <Icon name="phone" class="h-5 w-5 text-gold" /> {company.hotline}
      </a>
      <a href="#lien-he" data-mobile-link data-ripple class="btn btn-primary mt-3"><T t={ui.cta.consult} /></a>
    </nav>
  </div>
</header>

<style>
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -1px;
    height: 2px;
    width: 100%;
    background: var(--gradient-gold-metallic-h);
    transform: scaleX(0);
    transform-origin: center center;
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  [data-nav-link].is-active { color: var(--color-navy); }
  [data-nav-link].is-active::after { transform: scaleX(1); }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const icon = document.getElementById('menu-icon');

  const setMenu = (open: boolean) => {
    if (!menu || !toggle) return;
    menu.classList.toggle('hidden', !open);
    toggle.setAttribute('aria-expanded', String(open));
    const en = document.documentElement.getAttribute('data-lang') === 'en';
    toggle.setAttribute('aria-label', open ? (en ? 'Close menu' : 'Đóng menu') : (en ? 'Open menu' : 'Mở menu'));
    if (icon) {
      icon.innerHTML = open
        ? '<path d="M6 6l12 12M18 6 6 18"/>'
        : '<path d="M4 6h16M4 12h16M4 18h16"/>';
    }
    // Khoá cuộn nền khi menu mở để trang phía sau không chạy (best practice mobile).
    document.body.classList.toggle('no-scroll', open);
    const lock = (window as typeof window & { __ibsScrollLock?: (l: boolean) => void }).__ibsScrollLock;
    if (typeof lock === 'function') lock(open);
  };
  toggle?.addEventListener('click', () => setMenu(menu?.classList.contains('hidden') ?? true));
  document.querySelectorAll('[data-mobile-link]').forEach((a) =>
    a.addEventListener('click', () => setMenu(false))
  );

  const links = Array.from(document.querySelectorAll('[data-nav-link]')) as HTMLAnchorElement[];
  const sections = links
    .map((l) => document.querySelector(l.getAttribute('href') || ''))
    .filter(Boolean) as HTMLElement[];
  if ('IntersectionObserver' in window && sections.length) {
    const spy = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = '#' + entry.target.id;
            links.forEach((l) => l.classList.toggle('is-active', l.getAttribute('href') === id));
          }
        });
      },
      { rootMargin: '-45% 0px -50% 0px', threshold: 0 }
    );
    sections.forEach((s) => spy.observe(s));
  }
</script>
