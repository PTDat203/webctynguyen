---
import { Image } from 'astro:assets';
import { projects, ui } from '../data/site';
import { projectImages } from '../data/images';
import SectionHeader from './SectionHeader.astro';
import Icon from './Icon.astro';
import T from './T.astro';

// 4 dự án đại diện (mỗi nhóm một) + 1 thẻ CTA cuối.
const featured = [projects[0], projects[3], projects[5], projects[7]];
const slideTotal = featured.length + 1;
---
<section id="du-an" data-project-slider class="project-slider">
  <div class="ps-bg-layer" aria-hidden="true">
    {
      featured.map((p, i) => (
        <Image
          src={projectImages[p.title.vi]}
          alt=""
          widths={[768, 1280, 1920]}
          sizes="100vw"
          class:list={['ps-bg', i === 0 && 'is-active']}
          data-bg={i}
        />
      ))
    }
    <div class="ps-bg ps-bg-cta" data-bg={featured.length}></div>
    <div class="ps-bg-scrim"></div>
  </div>

  <div class="ps-inner container-ibs">
    <div class="ps-head">
      <SectionHeader overline={ui.projects.overline} title={ui.projects.title} align="left" light />
    </div>

    <div class="ps-stage">
      <div class="ps-text" data-ps-text>
        {
          featured.map((p, i) => (
            <article class:list={['ps-text-item', i === 0 && 'is-active']} data-text={i}>
              <span class="ps-cat"><T t={p.category} /></span>
              <h3 class="ps-title"><T t={p.title} /></h3>
              <p class="ps-desc"><T t={p.desc} /></p>
              <span class="ps-count">{String(i + 1).padStart(2, '0')}<i>/</i>{String(slideTotal).padStart(2, '0')}</span>
            </article>
          ))
        }
        <article class="ps-text-item ps-text-cta" data-text={featured.length}>
          <span class="ps-cat"><T t={ui.projects.moreOverline} /></span>
          <h3 class="ps-title"><T t={ui.projects.moreTitle} /></h3>
          <p class="ps-desc"><T t={ui.projects.moreDesc} /></p>
        </article>
      </div>

      <div class="ps-cards" data-ps-cards>
        <div class="ps-track" data-ps-track>
          {
            featured.map((p, i) => (
              <div class:list={['ps-card', i === 0 && 'is-active']} data-card={i}>
                <Image
                  src={projectImages[p.title.vi]}
                  alt={p.title.vi}
                  widths={[400, 800]}
                  sizes="(min-width:1024px) 36vw, 80vw"
                  class="ps-card-img"
                />
                <span class="ps-card-cat"><T t={p.category} /></span>
                <h4 class="ps-card-title"><T t={p.title} /></h4>
              </div>
            ))
          }
          <a href="#lien-he" class="ps-card ps-card-more" data-card={featured.length}>
            <span class="ps-more-plus" aria-hidden="true">+</span>
            <h4 class="ps-card-title"><T t={ui.projects.moreCard} /></h4>
            <span class="ps-more-cta">
              <T t={ui.projects.viewAll} /> <Icon name="arrow-right" class="h-4 w-4" />
            </span>
          </a>
        </div>
      </div>
    </div>

    <div class="ps-bar" data-ps-bar role="tablist" aria-label="Dự án">
      {
        Array.from({ length: slideTotal }).map((_, i) => (
          <button
            type="button"
            class:list={['ps-dot', i === 0 && 'is-active']}
            data-dot={i}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-label={`Mục ${i + 1}`}
          >
            <span class="ps-dot-num">{i + 1}</span>
          </button>
        ))
      }
    </div>

    <div class="ps-hint" data-ps-hint aria-hidden="true">
      <Icon name="chevron-down" class="ps-hint-icon h-5 w-5" />
      <span><T t={ui.projects.scrollHint} /></span>
    </div>
  </div>
</section>

<script>
  import '../scripts/projects.ts';
</script>
