---
import type { Bi } from '../data/site';
import T from './T.astro';

interface Props {
  overline?: Bi;
  title: Bi;
  intro?: Bi;
  align?: 'left' | 'center';
  light?: boolean;
  titleClass?: string;
}
const { overline, title, intro, align = 'center', light = false, titleClass = '' } = Astro.props;
const alignClass = align === 'center' ? 'mx-auto text-center' : 'text-left';
const dividerClass = align === 'center' ? 'mx-auto' : '';
---
<div data-section-header class={`max-w-2xl ${alignClass}`}>
  {overline && <p class="section-overline eyebrow mb-4"><T t={overline} /></p>}
  <h2 class={`section-title font-display text-3xl font-bold leading-tight md:text-[2.5rem] ${titleClass} ${light ? 'text-white' : ''}`}>
    <T t={title} />
  </h2>
  <span class={`section-divider gold-line-metallic mt-5 block h-px w-16 origin-center ${dividerClass}`}></span>
  {intro && (
    <p class={`section-intro mt-6 text-lg font-light leading-relaxed ${light ? 'text-white/70' : 'text-slate'}`}><T t={intro} /></p>
  )}
</div>
