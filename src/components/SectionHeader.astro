---
interface Props {
  overline?: string;
  title: string;
  intro?: string;
  align?: 'left' | 'center';
  light?: boolean;
}
const { overline, title, intro, align = 'center', light = false } = Astro.props;
const alignClass = align === 'center' ? 'mx-auto text-center' : 'text-left';
const dividerClass = align === 'center' ? 'mx-auto' : '';
---
<div data-section-header class={`max-w-2xl ${alignClass}`}>
  {overline && <p class="section-overline overline mb-4">{overline}</p>}
  <h2 class={`section-title font-display text-3xl font-bold leading-tight md:text-[2.5rem] ${light ? 'text-white' : ''}`}>
    {title}
  </h2>
  <span class={`section-divider mt-5 block h-px w-16 origin-center bg-gold ${dividerClass}`}></span>
  {intro && (
    <p class={`section-intro mt-6 text-lg font-light leading-relaxed ${light ? 'text-white/70' : 'text-slate'}`}>{intro}</p>
  )}
</div>
