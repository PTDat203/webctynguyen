---
interface Props {
  overline?: string;
  title: string;
  intro?: string;
  align?: 'left' | 'center';
  light?: boolean;
}
const { overline, title, intro, align = 'center', light = false } = Astro.props;
const alignClass = align === 'center' ? 'mx-auto text-center' : 'text-left';
---
<div class={`reveal max-w-2xl ${alignClass}`}>
  {overline && <p class="overline mb-4">{overline}</p>}
  <h2 class={`font-display text-3xl font-bold leading-tight md:text-[2.5rem] ${light ? 'text-white' : ''}`}>
    {title}
  </h2>
  <span class={`mt-5 block h-px w-16 bg-gold ${align === 'center' ? 'mx-auto' : ''}`}></span>
  {intro && (
    <p class={`mt-6 text-lg font-light leading-relaxed ${light ? 'text-white/70' : 'text-slate'}`}>{intro}</p>
  )}
</div>
