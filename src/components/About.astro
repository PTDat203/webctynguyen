---
import { Image } from 'astro:assets';
import { values } from '../data/site';
import { aboutImage } from '../data/images';
import Icon from './Icon.astro';
---
<section id="gioi-thieu" class="bg-white py-24 md:py-32">
  <div class="container-ibs">
    <div class="grid items-center gap-14 lg:grid-cols-2">
      <div class="reveal">
        <p class="overline mb-5">Về IBS</p>
        <h2 class="font-display text-3xl font-bold leading-tight md:text-[2.6rem]">
          Sức mạnh từ sự thấu hiểu và làm chủ
        </h2>
        <p class="mt-7 text-lg font-light leading-relaxed text-slate">
          IBS lập kế hoạch và điều hành triển lãm, hội chợ thương mại và sự kiện chuyên ngành theo
          tiêu chuẩn quốc tế — giải pháp toàn diện từ thiết kế, thi công đến vận hành và kết nối B2B.
        </p>
        <a href="#dich-vu" class="link-arrow mt-9">
          Khám phá dịch vụ <Icon name="arrow-right" class="h-4 w-4" />
        </a>
      </div>

      <div class="reveal relative">
        <Image
          src={aboutImage}
          alt="Không gian triển lãm & sự kiện do IBS thực hiện"
          widths={[400, 800, 1200]}
          sizes="(min-width:1024px) 50vw, 100vw"
          class="aspect-[4/3] w-full rounded-sm object-cover shadow-[var(--shadow-card)]"
        />
        <div class="absolute -bottom-6 -left-6 hidden bg-gold px-6 py-5 shadow-xl sm:block">
          <p class="font-display text-2xl font-bold leading-none text-white">ONE STOP</p>
          <p class="mt-1 text-xs font-semibold uppercase tracking-[0.2em] text-white/90">Services</p>
        </div>
      </div>
    </div>

    <div class="mt-20 grid gap-px overflow-hidden rounded-sm border border-mist bg-mist md:grid-cols-3">
      {
        values.map((v) => (
          <div class="reveal group bg-white p-8 transition-colors hover:bg-paper">
            <Icon name={v.icon} class="h-8 w-8 text-gold" />
            <h3 class="mt-5 font-display text-lg font-bold">{v.title}</h3>
            <p class="mt-2.5 text-[0.95rem] font-light leading-relaxed text-slate">{v.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
