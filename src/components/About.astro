---
import { Image } from 'astro:assets';
import { values, ui } from '../data/site';
import { aboutImage } from '../data/images';
import Icon from './Icon.astro';
import T from './T.astro';
---
<section id="gioi-thieu" class="bg-gradient-paper-soft py-24 md:py-32">
  <div class="container-ibs">
    <div class="grid items-center gap-14 lg:grid-cols-2">
      <div data-about-text>
        <p class="eyebrow mb-5"><T t={ui.about.overline} /></p>
        <h2 class="font-display text-3xl font-bold leading-tight md:text-[2.6rem]">
          <T t={ui.about.title} />
        </h2>
        <p class="mt-7 text-lg font-light leading-relaxed text-slate">
          <T t={ui.about.body} />
        </p>
        <a href="#dich-vu" class="link-arrow mt-9">
          <T t={ui.cta.exploreServices} /> <Icon name="arrow-right" class="h-4 w-4" />
        </a>
      </div>

      <div class="relative">
        <div data-about-image class="overflow-hidden rounded-sm shadow-[var(--shadow-card)]">
          <Image
            src={aboutImage}
            alt="Không gian triển lãm & sự kiện do IBS thực hiện"
            widths={[400, 800, 1200]}
            sizes="(min-width:1024px) 50vw, 100vw"
            class="aspect-[4/3] w-full object-cover"
          />
        </div>
        <div data-about-badge class="bg-gold-metallic absolute -bottom-6 -left-6 hidden px-6 py-5 shadow-xl sm:block">
          <p class="font-display text-2xl font-bold leading-none text-navy">ONE STOP</p>
          <p class="mt-1 text-xs font-semibold uppercase tracking-[0.2em] text-navy/80">Services</p>
        </div>
      </div>
    </div>

    <div class="mt-20 grid gap-px overflow-hidden rounded-sm border border-mist bg-mist md:grid-cols-3">
      {
        values.map((v) => (
          <div data-value-card data-tilt class="group bg-white p-8 transition-colors hover:bg-paper">
            <Icon name={v.icon} draw class="h-8 w-8 text-gold" />
            <h3 class="mt-5 font-display text-lg font-bold"><T t={v.title} /></h3>
            <p class="mt-2.5 text-[0.95rem] font-light leading-relaxed text-slate"><T t={v.body} /></p>
          </div>
        ))
      }
    </div>
  </div>
</section>
