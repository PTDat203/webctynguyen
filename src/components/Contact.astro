---
import { company, services } from '../data/site';
import Icon from './Icon.astro';
const mapSrc =
  'https://www.google.com/maps?q=' +
  encodeURIComponent('41A Lý Thái Tổ, Hoàn Kiếm, Hà Nội') +
  '&output=embed';
---
<section id="lien-he" class="bg-navy py-24 md:py-32">
  <div class="container-ibs">
    <div class="reveal mx-auto max-w-2xl text-center">
      <p class="overline">{company.oneStop}</p>
      <h2 class="mt-4 font-display text-3xl font-bold text-white md:text-[2.5rem]">
        Sẵn sàng nâng tầm triển lãm của bạn?
      </h2>
      <p class="mt-5 text-lg font-light text-white/70">
        Để lại thông tin — đội ngũ IBS sẽ tư vấn &amp; báo giá nhanh chóng, miễn phí.
      </p>
    </div>

    <div class="mt-14 grid gap-10 lg:grid-cols-2">
      <div class="reveal space-y-6">
        <ul class="space-y-5">
          <li class="flex items-start gap-4">
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-sm bg-white/10 text-gold">
              <Icon name="map-pin" class="h-5 w-5" />
            </span>
            <div>
              <p class="text-sm font-semibold text-white">Địa chỉ</p>
              <p class="text-sm font-light text-white/70">{company.address}</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-sm bg-white/10 text-gold">
              <Icon name="phone" class="h-5 w-5" />
            </span>
            <div>
              <p class="text-sm font-semibold text-white">Hotline ({company.hotlineNote})</p>
              <a href={company.hotlineHref} class="text-sm font-light text-white/70 transition-colors hover:text-gold">{company.hotline}</a>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-sm bg-white/10 text-gold">
              <Icon name="facebook" class="h-5 w-5" />
            </span>
            <div>
              <p class="text-sm font-semibold text-white">Facebook</p>
              <a href={company.facebook} target="_blank" rel="noopener" class="text-sm font-light text-white/70 transition-colors hover:text-gold">
                IBS Holdings
              </a>
            </div>
          </li>
        </ul>

        <div class="overflow-hidden rounded-sm border border-white/10">
          <iframe
            src={mapSrc}
            title="Bản đồ IBS — 41A Lý Thái Tổ, Hoàn Kiếm, Hà Nội"
            class="h-60 w-full"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>

      <div class="reveal rounded-sm bg-white p-8 shadow-xl md:p-10">
        <form action="https://api.web3forms.com/submit" method="POST" class="space-y-4">
          <!-- CẦN: thay bằng Access Key thật từ https://web3forms.com (miễn phí) -->
          <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_ACCESS_KEY" />
          <input type="hidden" name="subject" value="Liên hệ tư vấn từ website IBS" />
          <input type="hidden" name="from_name" value="Website IBS Holdings" />
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="name" class="mb-1.5 block text-sm font-medium text-ink">Họ và tên *</label>
              <input id="name" name="name" type="text" required class="form-field" placeholder="Nguyễn Văn A" />
            </div>
            <div>
              <label for="company" class="mb-1.5 block text-sm font-medium text-ink">Công ty</label>
              <input id="company" name="company" type="text" class="form-field" placeholder="Tên doanh nghiệp" />
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="email" class="mb-1.5 block text-sm font-medium text-ink">Email *</label>
              <input id="email" name="email" type="email" required class="form-field" placeholder="email@congty.com" />
            </div>
            <div>
              <label for="phone" class="mb-1.5 block text-sm font-medium text-ink">Số điện thoại *</label>
              <input id="phone" name="phone" type="tel" required class="form-field" placeholder="09xx xxx xxx" />
            </div>
          </div>

          <div>
            <label for="service" class="mb-1.5 block text-sm font-medium text-ink">Dịch vụ quan tâm</label>
            <select id="service" name="service" class="form-field">
              <option value="">— Chọn dịch vụ —</option>
              {services.map((s) => <option value={s.title}>{s.title}</option>)}
              <option value="Khác">Khác</option>
            </select>
          </div>

          <div>
            <label for="message" class="mb-1.5 block text-sm font-medium text-ink">Nội dung</label>
            <textarea id="message" name="message" rows="4" class="form-field" placeholder="Mô tả ngắn về nhu cầu của bạn..."></textarea>
          </div>

          <button type="submit" class="btn btn-primary w-full">Gửi yêu cầu tư vấn</button>
          <p class="text-center text-xs font-light text-slate">
            Hoặc gọi ngay <a href={company.hotlineHref} class="font-semibold text-navy hover:text-gold">{company.hotline}</a>
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .form-field {
    width: 100%;
    border-radius: 4px;
    border: 1px solid var(--color-mist);
    background: var(--color-paper);
    padding: 0.7rem 0.9rem;
    font-size: 0.95rem;
    color: var(--color-ink);
    transition: border-color 0.18s ease, box-shadow 0.18s ease;
  }
  .form-field:focus {
    outline: none;
    border-color: var(--color-sky);
    box-shadow: 0 0 0 3px rgba(46, 134, 214, 0.16);
    background: #fff;
  }
</style>
