---
import { company, services, ui } from '../data/site';
import Icon from './Icon.astro';
import T from './T.astro';
const mapSrc =
  'https://www.google.com/maps?q=' +
  encodeURIComponent('41A Lý Thái Tổ, Hoàn Kiếm, Hà Nội') +
  '&output=embed';
---
<section id="lien-he" class="bg-gradient-navy gradient-accent-top py-24 md:py-32">
  <div class="container-ibs">
    <div data-contact-header class="mx-auto max-w-2xl text-center">
      <p class="overline">{company.oneStop}</p>
      <h2 class="mt-4 font-display text-3xl font-bold text-white md:text-[2.5rem]">
        <T t={ui.contact.title} />
      </h2>
      <p class="mt-5 text-lg font-light text-white/70">
        <T t={ui.contact.sub} />
      </p>
    </div>

    <div class="mt-14 grid gap-10 lg:grid-cols-2">
      <div data-contact-info-col class="space-y-6">
        <ul class="space-y-5">
          <li data-contact-info class="flex items-start gap-4">
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-sm bg-white/10 text-gold">
              <Icon name="map-pin" class="h-5 w-5" />
            </span>
            <div>
              <p class="text-sm font-semibold text-white"><T t={ui.contact.addressLabel} /></p>
              <p class="text-sm font-light text-white/70"><T t={company.address} /></p>
            </div>
          </li>
          <li data-contact-info class="flex items-start gap-4">
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-sm bg-white/10 text-gold">
              <Icon name="phone" class="h-5 w-5" />
            </span>
            <div>
              <p class="text-sm font-semibold text-white"><T t={ui.contact.hotlineLabel} /> (<T t={company.hotlineNote} />)</p>
              <a href={company.hotlineHref} class="text-sm font-light text-white/70 transition-colors hover:text-gold">{company.hotline}</a>
            </div>
          </li>
          <li data-contact-info class="flex items-start gap-4">
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-sm bg-white/10 text-gold">
              <Icon name="facebook" class="h-5 w-5" />
            </span>
            <div>
              <p class="text-sm font-semibold text-white">Facebook</p>
              <a href={company.facebook} target="_blank" rel="noopener" class="text-sm font-light text-white/70 transition-colors hover:text-gold">
                IBS Holdings
              </a>
            </div>
          </li>
        </ul>

        <div data-contact-map class="overflow-hidden rounded-sm border border-white/10">
          <iframe
            src={mapSrc}
            title="Bản đồ IBS — 41A Lý Thái Tổ, Hoàn Kiếm, Hà Nội"
            class="h-60 w-full"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>

      <div data-contact-form class="rounded-sm bg-white p-8 shadow-xl md:p-10">
        <form action="https://api.web3forms.com/submit" method="POST" class="space-y-4">
          <!-- CẦN: thay bằng Access Key thật từ https://web3forms.com (miễn phí) -->
          <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_ACCESS_KEY" />
          <input type="hidden" name="subject" value="Liên hệ tư vấn từ website IBS" />
          <input type="hidden" name="from_name" value="Website IBS Holdings" />
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

          <div data-form-field class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="name" class="mb-1.5 block text-sm font-medium text-ink"><T t={ui.contact.formName} /></label>
              <input id="name" name="name" type="text" required class="form-field" placeholder={ui.contact.phName.vi} data-placeholder-vi={ui.contact.phName.vi} data-placeholder-en={ui.contact.phName.en} />
            </div>
            <div>
              <label for="company" class="mb-1.5 block text-sm font-medium text-ink"><T t={ui.contact.formCompany} /></label>
              <input id="company" name="company" type="text" class="form-field" placeholder={ui.contact.phCompany.vi} data-placeholder-vi={ui.contact.phCompany.vi} data-placeholder-en={ui.contact.phCompany.en} />
            </div>
          </div>

          <div data-form-field class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="email" class="mb-1.5 block text-sm font-medium text-ink"><T t={ui.contact.formEmail} /></label>
              <input id="email" name="email" type="email" required class="form-field" placeholder={ui.contact.phEmail.vi} data-placeholder-vi={ui.contact.phEmail.vi} data-placeholder-en={ui.contact.phEmail.en} />
            </div>
            <div>
              <label for="phone" class="mb-1.5 block text-sm font-medium text-ink"><T t={ui.contact.formPhone} /></label>
              <input id="phone" name="phone" type="tel" required class="form-field" placeholder={ui.contact.phPhone.vi} data-placeholder-vi={ui.contact.phPhone.vi} data-placeholder-en={ui.contact.phPhone.en} />
            </div>
          </div>

          <div data-form-field>
            <label for="service" class="mb-1.5 block text-sm font-medium text-ink"><T t={ui.contact.formService} /></label>
            <select id="service" name="service" class="form-field">
              <option value="" data-vi={ui.contact.formServicePlaceholder.vi} data-en={ui.contact.formServicePlaceholder.en}>{ui.contact.formServicePlaceholder.vi}</option>
              {services.map((s) => <option value={s.title.vi} data-vi={s.title.vi} data-en={s.title.en}>{s.title.vi}</option>)}
              <option value="Khác" data-vi={ui.contact.formServiceOther.vi} data-en={ui.contact.formServiceOther.en}>{ui.contact.formServiceOther.vi}</option>
            </select>
          </div>

          <div data-form-field>
            <label for="message" class="mb-1.5 block text-sm font-medium text-ink"><T t={ui.contact.formMessage} /></label>
            <textarea id="message" name="message" rows="4" class="form-field" placeholder={ui.contact.phMessage.vi} data-placeholder-vi={ui.contact.phMessage.vi} data-placeholder-en={ui.contact.phMessage.en}></textarea>
          </div>

          <div data-form-field>
            <button type="submit" class="btn btn-primary btn-glow w-full"><T t={ui.contact.submit} /></button>
            <p class="text-center text-xs font-light text-slate">
              <T t={ui.contact.orCall} /> <a href={company.hotlineHref} class="font-semibold text-navy hover:text-gold">{company.hotline}</a>
            </p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .form-field {
    width: 100%;
    border-radius: 4px;
    border: 1px solid var(--color-mist);
    background: var(--color-paper);
    padding: 0.7rem 0.9rem;
    font-size: 0.95rem;
    color: var(--color-ink);
    transition: border-color 0.18s ease, box-shadow 0.18s ease;
  }
  .form-field:focus {
    outline: none;
    border-color: var(--color-sky);
    box-shadow: 0 0 0 3px rgba(46, 134, 214, 0.16);
    background: #fff;
  }
</style>
