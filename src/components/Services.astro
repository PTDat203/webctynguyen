---
import { Image } from 'astro:assets';
import { services } from '../data/site';
import { serviceImages } from '../data/images';
import SectionHeader from './SectionHeader.astro';
import Icon from './Icon.astro';
---
<section id="dich-vu" class="bg-paper py-24 md:py-32">
  <div class="container-ibs">
    <SectionHeader
      overline="Dịch vụ"
      title="Giải pháp trọn gói cho mọi sự kiện"
      intro="Một điểm dừng — từ ý tưởng, thiết kế, thi công đến vận hành và truyền thông."
    />

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((s) => (
          <article class="reveal group flex flex-col overflow-hidden rounded-sm border border-mist bg-white shadow-[var(--shadow-card)] transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[var(--shadow-card-hover)]">
            <div class="relative aspect-[16/10] overflow-hidden">
              <Image
                src={serviceImages[s.id]}
                alt={s.title}
                widths={[400, 800]}
                sizes="(min-width:1024px) 33vw, (min-width:640px) 50vw, 100vw"
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-navy/75 via-navy/20 to-transparent"></div>
              <span class="absolute right-4 top-2 font-display text-5xl font-bold text-white/25">{s.no}</span>
              <div class="absolute bottom-4 left-4 grid h-11 w-11 place-items-center rounded-sm bg-gold text-white shadow-lg">
                <Icon name={s.icon} class="h-6 w-6" />
              </div>
            </div>
            <div class="flex flex-1 flex-col p-6">
              <h3 class="font-display text-lg font-bold leading-snug">{s.title}</h3>
              <p class="mt-2.5 flex-1 text-sm font-light leading-relaxed text-slate">{s.tagline}</p>
              <a href="#lien-he" class="link-arrow mt-5 text-[0.72rem]">
                Tìm hiểu thêm <Icon name="arrow-right" class="h-4 w-4" />
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
