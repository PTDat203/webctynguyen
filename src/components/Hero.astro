---
import { Image } from 'astro:assets';
import { company } from '../data/site';
import { heroImage } from '../data/images';
import Icon from './Icon.astro';
---
<section id="home" class="relative isolate flex min-h-[88vh] items-center overflow-hidden bg-navy">
  <div data-hero-image class="hero-ken-burns absolute inset-0 -z-10">
    <Image
      src={heroImage}
      alt="Triển lãm & sự kiện do IBS tổ chức"
      widths={[768, 1280, 1920]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      class="h-full w-full object-cover"
    />
  </div>
  <div data-hero-overlay class="absolute inset-0 -z-10 bg-gradient-to-r from-navy/90 via-navy/65 to-navy/30"></div>
  <div class="absolute inset-0 -z-10 bg-gradient-to-t from-navy/70 to-transparent"></div>

  <div class="container-ibs py-24">
    <div class="max-w-2xl">
      <div class="flex items-center gap-3">
        <span data-hero-gold-line class="h-px w-8 origin-left bg-gold"></span>
        <span data-hero-tagline class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">{company.tagline}</span>
      </div>
      <h1 class="mt-6 font-display text-4xl font-bold leading-[1.25] text-white sm:text-5xl md:text-6xl">
        <span class="hero-line block overflow-hidden">
          <span class="hero-line-inner block">Hệ sinh thái <span class="whitespace-nowrap text-gold">TRIỂN LÃM</span> toàn diện</span>
        </span>
      </h1>
      <p data-hero-subline class="mt-6 max-w-xl text-lg font-light leading-relaxed text-white/85">
        Một điểm dừng cho thiết kế &amp; thi công gian hàng, tổ chức sự kiện và kết nối kinh doanh B2B.
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-5">
        <a data-hero-cta href="#lien-he" class="btn btn-primary">Nhận tư vấn</a>
        <a data-hero-cta href="#du-an" class="link-arrow text-white">
          Xem dự án <Icon name="arrow-right" class="h-4 w-4" />
        </a>
      </div>
    </div>
  </div>

  <a
    data-hero-chevron
    href="#gioi-thieu"
    class="absolute bottom-8 left-1/2 hidden -translate-x-1/2 text-white/55 transition-colors hover:text-gold md:block"
    aria-label="Cuộn xuống"
  >
    <Icon name="chevron-down" class="h-7 w-7" />
  </a>
</section>
