---
import { Image } from 'astro:assets';
import { company, ui } from '../data/site';
import { heroImage } from '../data/images';
import Icon from './Icon.astro';
import T from './T.astro';
---
<section id="home" class="relative isolate flex min-h-[88vh] items-center overflow-hidden bg-navy">
  <div data-hero-image class="hero-ken-burns absolute inset-0 -z-10">
    <Image
      src={heroImage}
      alt="Triển lãm & sự kiện do IBS tổ chức"
      widths={[768, 1280, 1920]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      class="h-full w-full object-cover"
    />
  </div>
  <div data-hero-overlay class="hero-gradient-overlay absolute inset-0 -z-10"></div>
  <div class="hero-gradient-vignette absolute inset-0 -z-10"></div>

  <div class="container-ibs py-24">
    <div class="max-w-2xl">
      <div class="flex items-center gap-3">
        <span data-hero-gold-line class="gold-line-metallic h-px w-8 origin-left"></span>
        <span data-hero-tagline class="text-sm font-semibold uppercase tracking-[0.2em] text-gold-metallic"><T t={company.tagline} /></span>
      </div>
      <h1 class="mt-6 font-display text-4xl font-bold leading-[1.25] text-white sm:text-5xl md:text-6xl">
        <span class="hero-line block overflow-hidden">
          <span class="hero-line-inner block"
            ><span class="lang-vi">Hệ sinh thái <span class="whitespace-nowrap text-gold-metallic">TRIỂN LÃM</span> toàn diện</span><span class="lang-en">A complete <span class="whitespace-nowrap text-gold-metallic">EXHIBITION</span> ecosystem</span></span
          >
        </span>
      </h1>
      <p data-hero-subline class="mt-6 max-w-xl text-lg font-light leading-relaxed text-white/85">
        <T t={ui.hero.subline} />
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-5">
        <a data-hero-cta href="#lien-he" class="btn btn-primary"><T t={ui.cta.consult} /></a>
        <a data-hero-cta href="#du-an" class="link-arrow text-white">
          <T t={ui.cta.viewProjects} /> <Icon name="arrow-right" class="h-4 w-4" />
        </a>
      </div>
    </div>
  </div>

  <a
    data-hero-chevron
    href="#gioi-thieu"
    class="absolute bottom-8 left-1/2 hidden -translate-x-1/2 text-white/55 transition-colors hover:text-gold md:block"
    data-aria-label-vi={ui.cta.scrollDown.vi}
    data-aria-label-en={ui.cta.scrollDown.en}
    aria-label={ui.cta.scrollDown.vi}
  >
    <Icon name="chevron-down" class="h-7 w-7" />
  </a>
</section>
