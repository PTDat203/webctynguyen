---
import { Image } from 'astro:assets';
import { company } from '../data/site';
import { heroImage } from '../data/images';
import Icon from './Icon.astro';
---
<section id="home" class="relative isolate flex min-h-[88vh] items-center overflow-hidden bg-navy">
  <Image
    src={heroImage}
    alt="Triển lãm & sự kiện do IBS tổ chức"
    widths={[768, 1280, 1920]}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
    class="absolute inset-0 -z-10 h-full w-full object-cover"
  />
  <div class="absolute inset-0 -z-10 bg-gradient-to-r from-navy/90 via-navy/65 to-navy/30"></div>
  <div class="absolute inset-0 -z-10 bg-gradient-to-t from-navy/70 to-transparent"></div>

  <div class="container-ibs py-24">
    <div class="max-w-2xl">
      <div class="reveal flex items-center gap-3">
        <span class="h-px w-8 bg-gold"></span>
        <span class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">{company.tagline}</span>
      </div>
      <h1 class="reveal mt-6 font-display text-4xl font-bold leading-[1.25] text-white sm:text-5xl md:text-6xl">
        Hệ sinh thái <span class="whitespace-nowrap text-gold">TRIỂN LÃM</span> toàn diện
      </h1>
      <p class="reveal mt-6 max-w-xl text-lg font-light leading-relaxed text-white/85">
        Một điểm dừng cho thiết kế &amp; thi công gian hàng, tổ chức sự kiện và kết nối kinh doanh B2B.
      </p>
      <div class="reveal mt-10 flex flex-wrap items-center gap-5">
        <a href="#lien-he" class="btn btn-primary">Nhận tư vấn</a>
        <a href="#du-an" class="link-arrow text-white">
          Xem dự án <Icon name="arrow-right" class="h-4 w-4" />
        </a>
      </div>
    </div>
  </div>

  <a
    href="#gioi-thieu"
    class="absolute bottom-8 left-1/2 hidden -translate-x-1/2 text-white/55 transition-colors hover:text-gold md:block"
    aria-label="Cuộn xuống"
  >
    <Icon name="chevron-down" class="h-7 w-7 animate-bounce" />
  </a>
</section>
