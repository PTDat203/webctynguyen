---
import { Image } from 'astro:assets';
import { company, ui } from '../data/site';
import { heroImage } from '../data/images';
import heroKioskOverlay from '../assets/hero-kiosk-transparent.png';
import Icon from './Icon.astro';
import T from './T.astro';
---
<section id="home" class="relative isolate flex min-h-screen items-center overflow-hidden bg-navy">
  <div data-hero-image class="hero-ken-burns absolute inset-0 -z-10">
    <Image
      src={heroImage}
      alt="Triển lãm & sự kiện do IBS tổ chức"
      widths={[768, 1280, 1920]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      class="h-full w-full object-cover"
    />
  </div>
  <div data-hero-overlay class="hero-gradient-overlay absolute inset-0 -z-10"></div>
  <div class="hero-gradient-vignette absolute inset-0 -z-10"></div>
  <div data-hero-kiosk-image class="hero-kiosk-overlay" aria-hidden="true">
    <Image
      src={heroKioskOverlay}
      alt=""
      widths={[768, 1280, 1920]}
      sizes="100vw"
      loading="eager"
      class="h-full w-full object-cover"
    />
  </div>

  <div class="container-ibs relative z-10 py-16 md:py-20">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3">
        <span data-hero-gold-line class="gold-line-metallic h-px w-8 origin-left"></span>
        <span data-hero-tagline class="text-sm font-semibold uppercase tracking-[0.2em] text-gold-metallic"><T t={company.tagline} /></span>
      </div>
      <h1 class="hero-title mt-6 font-display text-[2.15rem] font-bold leading-[1.45] text-white sm:text-[2.8rem] md:text-[3.45rem] xl:text-[3.85rem]">
        <span class="hero-line block overflow-visible pt-1">
          <span class="hero-line-inner block"
            ><span class="lang-vi">Hệ sinh thái <span class="whitespace-nowrap text-gold-metallic font-black hero-highlight">TRIỂN LÃM</span> toàn diện</span><span class="lang-en">A complete <span class="whitespace-nowrap text-gold-metallic font-black hero-highlight">EXHIBITION</span> ecosystem</span></span
          >
        </span>
      </h1>
      <p data-hero-subline class="hero-subline mt-6 max-w-xl text-lg font-light leading-relaxed text-white/85">
        <T t={ui.hero.subline} />
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-5">
        <a data-hero-cta data-magnetic data-ripple href="#lien-he" class="btn btn-primary"><T t={ui.cta.consult} /></a>
        <a data-hero-cta data-magnetic href="#du-an" class="link-arrow text-white">
          <T t={ui.cta.viewProjects} /> <Icon name="arrow-right" class="h-4 w-4" />
        </a>
      </div>
    </div>
  </div>

  <a
    data-hero-chevron
    href="#gioi-thieu"
    class="absolute bottom-8 left-1/2 hidden -translate-x-1/2 text-white/55 transition-colors hover:text-gold md:block"
    data-aria-label-vi={ui.cta.scrollDown.vi}
    data-aria-label-en={ui.cta.scrollDown.en}
    aria-label={ui.cta.scrollDown.vi}
  >
    <Icon name="chevron-down" class="h-7 w-7" />
  </a>

  <style>
    .hero-kiosk-overlay {
      position: absolute;
      inset: 0;
      z-index: 18;
      display: none;
      pointer-events: none;
    }

    .hero-kiosk-overlay :global(img) {
      filter:
        drop-shadow(-22px 24px 30px rgba(0, 0, 0, 0.42))
        drop-shadow(0 0 18px rgba(255, 255, 255, 0.14));
    }

    .hero-title {
      text-shadow: 0 2px 14px rgba(0, 0, 0, 0.32);
    }

    .hero-subline {
      text-shadow: 0 1px 9px rgba(0, 0, 0, 0.3);
    }

    .hero-line {
      line-height: 1.55;
    }

    .hero-line-inner {
      display: inline-block;
      line-height: 1.55;
      overflow: visible;
      transform: translateY(0.04em);
    }

    .hero-line-inner .lang-vi,
    .hero-line-inner .lang-en {
      line-height: 1.45;
      overflow: visible;
    }

    .hero-line-inner .lang-vi {
      display: inline-block;
    }

    .hero-line-inner .lang-en {
      display: none;
    }

    :global(html[data-lang='en']) .hero-line-inner .lang-vi {
      display: none;
    }

    :global(html[data-lang='en']) .hero-line-inner .lang-en {
      display: inline-block;
    }

    .hero-highlight {
      display: inline-block;
      line-height: 1.45;
      padding-block: 0.08em 0;
      margin-block: -0.08em 0;
      overflow: visible;
    }

    @media (min-width: 1280px) and (hover: hover) and (pointer: fine) {
      .hero-kiosk-overlay {
        display: block;
      }
    }
  </style>
</section>
