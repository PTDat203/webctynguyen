  chart: '<path d="M4 4v16h16"/><path d="m7 14 3-3 3 2 5-6"/>',
  box: '<path d="M21 8 12 3 3 8l9 5 9-5Z"/><path d="M3 8v8l9 5 9-5V8M12 13v8"/>',
  globe: '<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/>',
  phone: '<path d="M5 3h4l2 5-2.5 1.5a11 11 0 0 0 5 5L20 11l1 4v4a2 2 0 0 1-2 2A16 16 0 0 1 3 5a2 2 0 0 1 2-2Z"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>',
  facebook: '<path d="M14 9V7c0-1 .5-1.5 1.5-1.5H17V2h-2.5C12 2 11 4 11 6v3H8.5v3.5H11V22h3v-9.5h2.5L17 9h-3Z"/>',
  'arrow-right': '<path d="M5 12h14M13 6l6 6-6 6"/>',
  'map-pin': '<path d="M12 21s7-5.5 7-11a7 7 0 1 0-14 0c0 5.5 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/>',
  check: '<path d="m4 12 5 5L20 6"/>',
