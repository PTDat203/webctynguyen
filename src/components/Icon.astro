---
// Line-icon set (24x24, currentColor stroke). Usage: <Icon name="booth" class="w-6 h-6" />
interface Props {
  name: string;
  class?: string;
  id?: string;
}
const { name, class: className = 'w-6 h-6', id } = Astro.props;

const paths: Record<string, string> = {
