---
import { stats } from '../data/site';
import T from './T.astro';
---
<section data-stats-bar data-blueprint data-spotlight class="bg-gradient-navy gradient-accent-top py-14 md:py-16">
  <div class="container-ibs grid grid-cols-2 gap-8 lg:grid-cols-4">
    {
      stats.map((s) => (
        <div data-stat-item class="flex flex-col items-center text-center">
          <div class="inline-flex flex-col items-center">
            <div
              class="font-display text-4xl font-extrabold leading-none text-gold-metallic md:text-5xl"
              data-counter
              data-target={s.value}
              data-suffix={s.suffix}
            >
              0{s.suffix}
            </div>
            <span class="stat-underline gold-line-metallic mt-3 block h-0.5 w-12 origin-center"></span>
          </div>
          <p class="mt-3 text-sm font-light tracking-wide text-white/65"><T t={s.label} /></p>
        </div>
      ))
    }
  </div>
</section>
