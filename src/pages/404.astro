---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Không tìm thấy trang | IBS Holdings" description="Trang bạn tìm không tồn tại.">
  <section class="grid min-h-[60vh] place-items-center bg-paper py-24">
    <div class="container-ibs text-center">
      <p class="font-display text-7xl font-extrabold text-gold">404</p>
      <h1 class="mt-4 font-display text-2xl font-bold md:text-3xl">Không tìm thấy trang</h1>
      <p class="mt-3 text-slate">Trang bạn đang tìm không tồn tại hoặc đã được di chuyển.</p>
      <a href="/" class="btn btn-outline-navy mt-7">Về trang chủ</a>
    </div>
  </section>
</BaseLayout>
