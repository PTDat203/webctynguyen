---
import '../styles/global.css';
import Seo from '../components/Seo.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SideDots from '../components/SideDots.astro';
import T from '../components/T.astro';
import { ui, company } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}
const { title, description } = Astro.props;
---
<!doctype html>
<html
  lang="vi"
  data-lang="vi"
  data-title-vi={ui.seo.title.vi}
  data-title-en={ui.seo.title.en}
  data-desc-vi={ui.seo.description.vi}
  data-desc-en={ui.seo.description.en}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png?v=3" />
    <link rel="apple-touch-icon" href="/favicon.png?v=3" />
    <meta name="theme-color" content="#0c3a75" />
    <script is:inline>
      (function () {
        try {
          var l = localStorage.getItem('ibs-lang') === 'en' ? 'en' : 'vi';
          document.documentElement.setAttribute('data-lang', l);
          document.documentElement.lang = l;
        } catch (e) {}
      })();
    </script>
    <Seo title={title} description={description} />
    <noscript>
      <style>
        body.is-loading { overflow: auto !important; }
        body.is-loading .site-header,
        body.is-loading main { opacity: 1 !important; }
        .fx-loader { display: none !important; }
      </style>
    </noscript>
  </head>
  <body class="is-loading">
    <script is:inline>
      // An toàn: luôn gỡ trạng thái loading kể cả khi module script lỗi.
      (function () {
        var pageReady =
          document.readyState === 'complete'
            ? Promise.resolve()
            : new Promise(function (resolve) {
                window.addEventListener('load', resolve, { once: true });
              });
        var minimumDelay = new Promise(function (resolve) {
          window.setTimeout(resolve, 1500);
        });

        Promise.all([pageReady, minimumDelay]).then(function () {
          document.body.classList.remove('is-loading');
          document.body.classList.add('is-loaded');
        });
      })();
    </script>
    <div class="fx-loader" data-loader aria-hidden="true">
      <div class="fx-loader-inner">
        <div class="fx-loader-logo">
          <i class="fx-loader-ring"></i>
          <i class="fx-loader-ring two"></i>
          <span class="fx-loader-mark">IBS</span>
        </div>
        <div class="fx-loader-word">
          <b>HOLDINGS</b>
          <em>International Business Services</em>
        </div>
        <div class="fx-loader-track"><span data-loader-bar></span></div>
      </div>
    </div>

    <div class="fx-cursor-glow" data-cursor-glow aria-hidden="true"></div>
    <div class="fx-cursor-dot" data-cursor-dot aria-hidden="true"></div>
    <div class="fx-cursor-ring" data-cursor-ring aria-hidden="true"></div>

    <div
      data-scroll-progress
      class="pointer-events-none fixed left-0 top-0 z-[60] h-1 w-full origin-left"
      aria-hidden="true"
    ></div>

    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded focus:bg-navy focus:px-4 focus:py-2 focus:text-white">
      <T t={ui.cta.skipToContent} />
    </a>
    <Header />
    <SideDots />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <div id="contact-fab" class="fixed bottom-6 left-6 z-40 flex flex-col items-center gap-3">
      <div class="contact-fab-actions" data-fab-actions>
        <a
          class="contact-fab-action messenger"
          data-fab-item
          href={company.messenger}
          target="_blank"
          rel="noopener noreferrer"
          data-aria-label-vi={ui.cta.chatMessenger.vi}
          data-aria-label-en={ui.cta.chatMessenger.en}
          aria-label={ui.cta.chatMessenger.vi}
        >
          <span class="contact-fab-label"><T t={ui.cta.chatMessenger} /></span>
          <span class="contact-fab-bubble">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.36 2 2 6.13 2 11.7c0 2.91 1.19 5.44 3.14 7.19.16.15.26.35.27.57l.05 1.78c.02.57.6.94 1.12.71l1.99-.88c.17-.07.36-.09.54-.04 .91.25 1.88.39 2.89.39 5.64 0 10-4.13 10-9.7C22 6.13 17.64 2 12 2Zm6 7.46-2.93 4.66c-.47.74-1.47.93-2.18.4l-2.33-1.75a.6.6 0 0 0-.72 0l-3.15 2.39c-.42.32-.97-.18-.69-.63l2.93-4.66c.47-.74 1.47-.93 2.18-.4l2.33 1.75a.6.6 0 0 0 .72 0l3.15-2.39c.42-.32.97.18.69.63Z"/>
            </svg>
          </span>
        </a>
        <a
          class="contact-fab-action zalo"
          data-fab-item
          href={company.zalo}
          target="_blank"
          rel="noopener noreferrer"
          data-aria-label-vi={ui.cta.chatZalo.vi}
          data-aria-label-en={ui.cta.chatZalo.en}
          aria-label={ui.cta.chatZalo.vi}
        >
          <span class="contact-fab-label"><T t={ui.cta.chatZalo} /></span>
          <span class="contact-fab-bubble">
            <svg class="contact-fab-zalo" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12.49 10.2722v-.4496h1.3467v6.3218h-.7704a.576.576 0 01-.5763-.5729l-.0006.0005a3.273 3.273 0 01-1.9372.6321c-1.8138 0-3.2844-1.4697-3.2844-3.2823 0-1.8125 1.4706-3.2822 3.2844-3.2822a3.273 3.273 0 011.9372.6321l.0006.0005zM6.9188 7.7896v.205c0 .3823-.051.6944-.2995 1.0605l-.03.0343c-.0542.0615-.1815.206-.2421.2843L2.024 14.8h4.8948v.7682a.5764.5764 0 01-.5767.5761H0v-.3622c0-.4436.1102-.6414.2495-.8476L4.8582 9.23H.1922V7.7896h6.7266zm8.5513 8.3548a.4805.4805 0 01-.4803-.4798v-7.875h1.4416v8.3548H15.47zM20.6934 9.6C22.52 9.6 24 11.0807 24 12.9044c0 1.8252-1.4801 3.306-3.3066 3.306-1.8264 0-3.3066-1.4808-3.3066-3.306 0-1.8237 1.4802-3.3044 3.3066-3.3044zm-10.1412 5.253c1.0675 0 1.9324-.8645 1.9324-1.9312 0-1.065-.865-1.9295-1.9324-1.9295s-1.9324.8644-1.9324 1.9295c0 1.0667.865 1.9312 1.9324 1.9312zm10.1412-.0033c1.0737 0 1.945-.8707 1.945-1.9453 0-1.073-.8713-1.9436-1.945-1.9436-1.0753 0-1.945.8706-1.945 1.9436 0 1.0746.8697 1.9453 1.945 1.9453z"/>
            </svg>
          </span>
        </a>
        <a
          class="contact-fab-action sms"
          data-fab-item
          href={company.smsHref}
          data-aria-label-vi={ui.cta.sendSms.vi}
          data-aria-label-en={ui.cta.sendSms.en}
          aria-label={ui.cta.sendSms.vi}
        >
          <span class="contact-fab-label"><T t={ui.cta.sendSms} /></span>
          <span class="contact-fab-bubble">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 11.5a8.38 8.38 0 0 1-9 8.33L3 21l1.17-3.5A8.38 8.38 0 1 1 21 11.5Z"/>
            </svg>
          </span>
        </a>
        <a
          class="contact-fab-action call"
          data-fab-item
          href={company.hotlineHref}
          data-aria-label-vi={ui.cta.callHotline.vi}
          data-aria-label-en={ui.cta.callHotline.en}
          aria-label={ui.cta.callHotline.vi}
        >
          <span class="contact-fab-label"><T t={ui.cta.callHotline} /></span>
          <span class="contact-fab-bubble">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2a1 1 0 0 1 1.02-.24c1.12.37 2.33.57 3.57.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.24.2 2.45.57 3.57a1 1 0 0 1-.24 1.02l-2.21 2.2Z"/>
            </svg>
          </span>
        </a>
      </div>

      <button
        id="contact-fab-toggle"
        type="button"
        aria-haspopup="true"
        aria-expanded="false"
        data-aria-label-vi={ui.cta.moreContact.vi}
        data-aria-label-en={ui.cta.moreContact.en}
        aria-label={ui.cta.moreContact.vi}
        class="grid h-12 w-12 place-items-center rounded-full text-white shadow-lg ring-1 ring-white/20"
      >
        <svg class="contact-fab-icon-main h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 14v-2a8 8 0 0 1 16 0v2" />
          <path d="M18 19.5a2.5 2.5 0 0 1-2.5 2.5H13" />
          <rect x="2.5" y="13.5" width="3.8" height="6.5" rx="1.4" />
          <rect x="17.7" y="13.5" width="3.8" height="6.5" rx="1.4" />
        </svg>
        <svg class="contact-fab-icon-close h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 6l12 12M18 6 6 18" />
        </svg>
        <span class="messenger-fab-pulse" aria-hidden="true"></span>
      </button>
    </div>

    <button
      id="back-to-top"
      type="button"
      data-aria-label-vi={ui.cta.backToTop.vi}
      data-aria-label-en={ui.cta.backToTop.en}
      aria-label={ui.cta.backToTop.vi}
      class="fixed bottom-6 right-6 z-40 grid h-12 w-12 place-items-center rounded-full bg-navy text-gold shadow-lg ring-1 ring-white/15 hover:bg-gold hover:text-navy"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 19V5M5 12l7-7 7 7" />
      </svg>
    </button>

    <script>
      import '../scripts/smooth-scroll.ts';
      import '../scripts/motion.ts';
      import '../scripts/i18n.ts';
      import '../scripts/fx.ts';
    </script>

    <script>
      // Speed-dial liên hệ: bấm nút chính để bung danh sách (Messenger / Zalo / SMS / Gọi).
      (function () {
        const wrap = document.getElementById('contact-fab');
        const toggle = document.getElementById('contact-fab-toggle');
        if (!wrap || !toggle) return;

        const hoverCapable = window.matchMedia('(hover: hover)').matches;

        const isOpen = () => wrap.classList.contains('is-open');
        const setOpen = (open: boolean) => {
          wrap.classList.toggle('is-open', open);
          toggle.setAttribute('aria-expanded', String(open));
        };

        toggle.addEventListener('click', (e) => {
          e.stopPropagation();
          setOpen(!isOpen());
        });

        // Trên desktop: rê chuột để bung, rời ra để thu lại.
        if (hoverCapable) {
          wrap.addEventListener('mouseenter', () => setOpen(true));
          wrap.addEventListener('mouseleave', () => setOpen(false));
        }

        // Chạm vào một mục liên hệ hoặc bấm ra ngoài thì thu lại.
        wrap.querySelectorAll('[data-fab-item]').forEach((el) =>
          el.addEventListener('click', () => setOpen(false))
        );
        const closeIfOutside = (e: Event) => {
          if (!wrap.contains(e.target as Node)) setOpen(false);
        };
        document.addEventListener('click', closeIfOutside);
        // touchstart: iOS không phải lúc nào cũng phát 'click' khi chạm vùng trống.
        document.addEventListener('touchstart', closeIfOutside, { passive: true });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') setOpen(false);
        });
      })();
    </script>
  </body>
</html>
